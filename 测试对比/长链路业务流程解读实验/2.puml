' ============================================================
' 关系连线
' ============================================================

' --- 阶段1内部关系 ---
PreOrder --> MallOrder : "1:1 预购单转订单\n(PreOrderService.createOrder)"
MallOrder --> OrderDetail : "1:N 订单含明细\n(主订单ID)"

' --- 阶段1→阶段2：下单到拆单 ---
MallOrder --> ParentSplit : "1:1 生成父拆单\n(MallOrderBackSplitDO.of)\nmain_order_id关联"

' --- 阶段2内部关系 ---
ParentSplit --> ParentSplit : "1:N 拆分为子单\n(ManualSplitOrderBiz.split)\nparent_split_id自关联"
ParentSplit --> SplitDetail : "1:N 拆单含明细\n(split_order_id关联)"

' --- 阶段2→库存锁定 ---
ParentSplit ..> StockLock : "拆单后触发\n(RocketMQ消息)\nStockWarehouseCityProducer"
ParentSplit ..> DispatchLock : "拆单后触发\n(MallDispatchLockRecordBiz)\nsplit_order_id关联"

' --- 库存锁定内部 ---
DispatchLock --> SplitDetail : "N:1 锁定关联明细\n(split_order_detail_id)"

' --- 阶段2→阶段3：拆单到备货 ---
ParentSplit --> DeliveryConfirm : "1:N 创建发货确认单\n(WmsDeliveryConfirmationBiz)\nmall_order_id关联"

' --- 阶段3内部关系 ---
DeliveryConfirm --> OutStorage : "1:N 生成出库单\ncreateSalesOutStorageOrder\n(平台仓)/createTransfer\nOutStorageOrder(供应商仓)"
OutStorage --> OutStorageDetail : "1:N 出库含明细"
DeliveryConfirm ..> WmsDelivery : "1:N 出库后生成发货单\n(WmsDeliveryOrderProducer\n→RocketMQ)"

' --- 阶段3→阶段4：出库到配送 ---
WmsDelivery ..> DeliveryOrder : "WMS发货单→物流配送单\n(RocketMQ→logis模块)\nWmsDeliveryOrderMsg"

' --- 阶段4内部关系 ---
DeliveryOrder --> DistributedOrder : "1:1 派车调度\n(LogisticsDistributedOrder)"
DeliveryOrder --> Package : "1:N 配送单含包裹\n(delivery_order_id关联)"
Package --> MallOrder : "N:1 包裹关联主订单\n(main_order_id)"

' ============================================================
' 流转注释
' ============================================================
note top of PreOrder
  <b>入口</b>: OrderController.preOrder()
  → ApiOrderBiz.preOrder()
  → MallOrderFacade.preOrder()
  → PreOrderService.createOrder()
  校验SKU可用性、计算运费、金额校验
end note

note top of ParentSplit
  <b>入口</b>: ManualSplitOrderBiz.split()
  1. 校验父拆单
  2. 按供应商+仓库分组
  3. 单供应商→更新父单
  4. 多供应商→生成子单
  5. 触发库存锁定
  6. 更新拆单状态
end note

note top of DeliveryConfirm
  <b>入口</b>: WmsDeliveryConfirmationBiz
  1. 创建发货确认单
  2. 基于子单明细查询库存锁定
  3. 销售出库(平台仓)
     createSalesOutStorageOrder()
  4. 调拨出库(供应商仓)
     createTransferOutStorageOrder()
end note

note top of DeliveryOrder
  <b>入口</b>: DeliveryOrderBiz
  1. 生成配送单
  2. 派车调度
  3. 司机取货→startDeliveryOrder()
     状态: 未到达→已到达
  4. 司机配送→confirmDeliveryOrder()
     状态: 已到达→已完成
end note

@enduml
